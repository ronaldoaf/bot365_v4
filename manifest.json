{
   "action": {
      "default_icon": "images/logo_32.png",
      "default_popup": "popup.html",
      "default_title": "Bot365 v5"
   },
   "description": "Faz umas apostas em Under",
   "icons": {
      "32": "images/logo_32.png",
      "64": "images/logo_64.png"
   },
   "manifest_version": 3,
   "name": "Bot365 v5",
   "permissions": [
      "storage",
      "unlimitedStorage",
      "tabs",
      "alarms"
   ],
   "host_permissions": [
      "http://localhost:1313/*",
      "https://bot-ao.com/*",
      "https://www.bet365.bet.br/*"
   ],
   "version": "1.14.0",
   "web_accessible_resources": [
      {
         "resources": [ "images/*", "js/ort/*.wasm", "model.onnx","model_gl.onnx" ],
         "matches": [ "https://www.bet365.bet.br/*" ]
      }
   ],
   "background": {
      "service_worker": "js/background.js"
   },
   "content_scripts": [
      {
         "matches": [ "https://www.bet365.bet.br/*" ],
         "js": ["js/shared.js","js/selectors.js","js/logger.js","js/ort/ort.min.js","js/content.js"]
      }
   ]
}
